            "code": "it",
            "dir": "ltr",
            "name": "Italiano"
          },
          {
            "code": "en",
            "dir": "ltr",
            "name": "English"
          }
        ],
        "preferredDistributionId": "ch.bafu.neophyten-felsen_greiskraut:wmts",
        "title": "Felsen-Greiskraut",
        "type": "Dataset"
      }
