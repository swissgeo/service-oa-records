            "dir": "ltr",
            "name": "Italiano"
          },
          {
            "code": "en",
            "dir": "ltr",
            "name": "English"
          }
        ],
        "preferredDistributionId": "ch.bafu.geochemischer-bodenatlas_schweiz_kupfer:wmts",
        "title": "Kupfer-Konzentrationen im Boden",
        "type": "Dataset"
      }
