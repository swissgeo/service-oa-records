        },
        {
          "href": "https://www.geocat.ch/geonetwork/srv/ger/catalog.search#/metadata/053bcacc-0ae4-4e03-9a79-9e0ecb56cd77",
          "rel": "alternate",
          "title": "GeoCat Metadata"
        }
      ],
      "type": "Feature",
