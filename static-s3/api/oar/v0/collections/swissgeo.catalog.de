        {
          "href": "https://www.geocat.ch/geonetwork/srv/api/records/849ba7b6-25d3-40c1-bccd-c91bf3f84d39/attachments/Datenbeschreibung_Fokuskarte_V%C3%B6gel%20de_fr_engl.pdf",
          "rel": "describedby",
