    {
      "id": "ch.bafu.geochemischer-bodenatlas_schweiz_cadmium",
      "links": [
        {
          "href": "https://services.dev.sgdi.tech/api/oar/v0/collections/swissgeo.catalog/items/ch.bafu.geochemischer-bodenatlas_schweiz_cadmium?language=de",
