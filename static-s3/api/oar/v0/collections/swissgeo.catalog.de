            "dir": "ltr",
            "name": "Italiano"
          },
          {
            "code": "en",
            "dir": "ltr",
            "name": "English"
          }
        ],
        "preferredDistributionId": "ch.bafu.geochemischer-bodenatlas_schweiz_natrium:wmts",
        "title": "Natrium - Konzentrationen im Boden",
        "type": "Dataset"
      }
