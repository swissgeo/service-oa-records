    {
      "id": "ch.bafu.niederschlagserosivitaet-apr",
      "links": [
        {
          "href": "https://services.dev.sgdi.tech/api/oar/v0/collections/swissgeo.catalog/items/ch.bafu.niederschlagserosivitaet-apr?language=de",
