            "name": "Italiano"
          },
          {
            "code": "en",
            "dir": "ltr",
            "name": "English"
          }
        ],
        "preferredDistributionId": "ch.bafu.amphibienwanderung-verkehrskonflikte:wmts",
        "title": "Amphibienwanderungen mit Konflikten",
        "type": "Dataset"
      }
