        },
        {
          "href": "https://www.geocat.ch/geonetwork/srv/ger/catalog.search#/metadata/7fd70db8-3128-4734-99ac-b1cf46cfcad8",
          "rel": "alternate",
          "title": "GeoCat Metadata"
        }
      ],
      "type": "Feature",
