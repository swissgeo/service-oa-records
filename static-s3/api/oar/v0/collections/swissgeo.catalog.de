      "id": "ch.bafu.niederschlagserosivitaet-jul",
      "links": [
        {
          "href": "https://services.dev.sgdi.tech/api/oar/v0/collections/swissgeo.catalog/items/ch.bafu.niederschlagserosivitaet-jul?language=de",
