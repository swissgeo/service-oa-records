            "dir": "ltr",
            "name": "English"
          }
        ],
        "preferredDistributionId": "ch.bafu.niederschlagserosivitaet-okt:wmts",
        "title": "Niederschlagserosivität Okt.",
        "type": "Dataset"
      }
