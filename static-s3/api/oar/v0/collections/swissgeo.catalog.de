      "id": "ch.agroscope.korridore-feuchtgebietsarten_bereiche",
      "links": [
        {
          "href": "https://services.dev.sgdi.tech/api/oar/v0/collections/swissgeo.catalog/items/ch.agroscope.korridore-feuchtgebietsarten_bereiche?language=de",
