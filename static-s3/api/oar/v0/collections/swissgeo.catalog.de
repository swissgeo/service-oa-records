    {
      "id": "ch.agroscope.amphibien-ausbreitungskarten_triturus_cristatus",
      "links": [
        {
          "href": "https://services.dev.sgdi.tech/api/oar/v0/collections/swissgeo.catalog/items/ch.agroscope.amphibien-ausbreitungskarten_triturus_cristatus?language=de",
