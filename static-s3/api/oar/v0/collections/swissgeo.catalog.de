      "id": "ch.bafu.geochemischer-bodenatlas_schweiz_vanadium",
      "links": [
        {
          "href": "https://services.dev.sgdi.tech/api/oar/v0/collections/swissgeo.catalog/items/ch.bafu.geochemischer-bodenatlas_schweiz_vanadium?language=de",
