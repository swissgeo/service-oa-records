            "name": "Italiano"
          },
          {
            "code": "en",
            "dir": "ltr",
            "name": "English"
          }
        ],
        "preferredDistributionId": "ch.bafu.geochemischer-bodenatlas_schweiz_uran:wmts",
        "title": "Uran-Konzentrationen im Boden",
        "type": "Dataset"
      }
