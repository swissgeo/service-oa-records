            "name": "Italiano"
          },
          {
            "code": "en",
            "dir": "ltr",
            "name": "English"
          }
        ],
        "preferredDistributionId": "ch.swisstopo.hebungsraten:wms",
        "title": "Vertikalbewegungen",
        "type": "Dataset"
      }
    },
