            "dir": "ltr",
            "name": "Italiano"
          },
          {
            "code": "en",
            "dir": "ltr",
            "name": "English"
          }
        ],
        "preferredDistributionId": "ch.bfe.ladebedarfswelt-ladepunkte_geplant:wmts",
        "title": "Ladebedarf: Ladepunkte - Geplant",
        "type": "Dataset"
      }
