      "id": "ch.bafu.geochemischer-bodenatlas_schweiz_chrom",
      "links": [
        {
          "href": "https://services.dev.sgdi.tech/api/oar/v0/collections/swissgeo.catalog/items/ch.bafu.geochemischer-bodenatlas_schweiz_chrom?language=de",
