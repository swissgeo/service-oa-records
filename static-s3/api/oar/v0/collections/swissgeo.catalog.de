        }
      ],
      "type": "Feature",
      "geometry": {
        "coordinates": [
          [
            [
              5.96,
              45.82
            ],
            [
              5.96,
              47.81
            ],
            [
              10.49,
              47.81
            ],
            [
              10.49,
              45.82
            ],
