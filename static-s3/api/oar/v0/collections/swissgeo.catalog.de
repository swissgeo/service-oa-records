            "name": "Italiano"
          },
          {
            "code": "en",
            "dir": "ltr",
            "name": "English"
          }
        ],
        "preferredDistributionId": "ch.bafu.geochemischer-bodenatlas_schweiz_calcium:wmts",
        "title": "Calcium - Konzentrationen im Boden",
        "type": "Dataset"
      }
