    {
      "id": "ch.meteoschweiz.hagelgefaehrdung-korngroesse_20_jahre",
      "links": [
        {
          "href": "https://services.dev.sgdi.tech/api/oar/v0/collections/swissgeo.catalog/items/ch.meteoschweiz.hagelgefaehrdung-korngroesse_20_jahre?language=de",
