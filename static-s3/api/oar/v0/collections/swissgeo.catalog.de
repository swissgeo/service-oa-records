            "code": "it",
            "dir": "ltr",
            "name": "Italiano"
          },
          {
            "code": "en",
            "dir": "ltr",
            "name": "English"
          }
        ],
        "preferredDistributionId": "ch.bafu.geochemischer-bodenatlas_schweiz_nickel:wmts",
        "title": "Nickel-Konzentrationen im Boden",
        "type": "Dataset"
      }
