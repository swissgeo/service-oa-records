      "id": "ch.bafu.niederschlagserosivitaet-mrz",
      "links": [
        {
          "href": "https://services.dev.sgdi.tech/api/oar/v0/collections/swissgeo.catalog/items/ch.bafu.niederschlagserosivitaet-mrz?language=de",
