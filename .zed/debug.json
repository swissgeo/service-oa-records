  {
    "adapter": "Debugpy",
    "label": "Attach to Docker (swissgeo_provider)",
    "request": "attach",
    "connect": {
      "host": "127.0.0.1",
      "port": 5678,
    },
    "pathMappings": [
      {
        "localRoot": "$ZED_WORKTREE_ROOT/pygeoapi-swissgeo-extensions",
        "remoteRoot": "/pygeoapi/pygeoapi-swissgeo-extensions",
      },
    ],
  },
]
