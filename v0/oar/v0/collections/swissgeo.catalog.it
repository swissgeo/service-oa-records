            "code": "it",
            "dir": "ltr",
            "name": "Italiano"
          },
          {
            "code": "en",
            "dir": "ltr",
            "name": "English"
          }
        ],
        "preferredDistributionId": "ch.agroscope.korridore-feuchtgebietsarten_bereiche:wmts",
        "title": "Corridors zones humides – Zones",
        "type": "Dataset"
      }
