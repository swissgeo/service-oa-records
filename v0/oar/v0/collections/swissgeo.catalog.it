      "id": "ch.bafu.niederschlagserosivitaet-dez",
      "links": [
        {
          "href": "https://services.dev.sgdi.tech/api/oar/v0/collections/swissgeo.catalog/items/ch.bafu.niederschlagserosivitaet-dez?language=it",
