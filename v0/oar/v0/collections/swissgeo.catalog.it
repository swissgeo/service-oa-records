            "dir": "ltr",
            "name": "Italiano"
          },
          {
            "code": "en",
            "dir": "ltr",
            "name": "English"
          }
        ],
        "preferredDistributionId": "ch.bafu.landesforstinventar-vegetationshoehenmodell_relief:wmts",
        "title": "Modello della superficie terrestre IFN",
        "type": "Dataset"
      }
    },
