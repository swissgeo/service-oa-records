          },
          {
            "code": "en",
            "dir": "ltr",
            "name": "English"
          }
        ],
        "preferredDistributionId": "ch.bafu.geochemischer-bodenatlas_schweiz_uran:wmts",
        "title": "Concentrazioni d'uranio nel suolo",
        "type": "Dataset"
      }
