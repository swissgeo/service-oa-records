            "dir": "ltr",
            "name": "Italiano"
          },
          {
            "code": "en",
            "dir": "ltr",
            "name": "English"
          }
        ],
        "preferredDistributionId": "ch.swisstopo.geologie-tiefengeothermie_projekte:wms",
        "title": "Progetti di geotermia profonda",
        "type": "Dataset"
      }
