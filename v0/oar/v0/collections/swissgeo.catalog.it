            "dir": "ltr",
            "name": "Italiano"
          },
          {
            "code": "en",
            "dir": "ltr",
            "name": "English"
          }
        ],
        "preferredDistributionId": "ch.bfe.windenergie-geschwindigkeit_h100:wms",
        "title": "Velocità vento a 100 m dal suolo",
        "type": "Dataset"
      }
