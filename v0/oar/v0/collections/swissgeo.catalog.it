            "name": "Italiano"
          },
          {
            "code": "en",
            "dir": "ltr",
            "name": "English"
          }
        ],
        "preferredDistributionId": "ch.bafu.geochemischer-bodenatlas_schweiz_nickel:wmts",
        "title": "Concentrazioni di nickel nel suolo",
        "type": "Dataset"
      }
