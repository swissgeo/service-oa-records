    {
      "id": "ch.bfe.windenergie-geschwindigkeit_h50",
      "links": [
        {
          "href": "https://services.dev.sgdi.tech/api/oar/v0/collections/swissgeo.catalog/items/ch.bfe.windenergie-geschwindigkeit_h50?language=it",
          "rel": "self",
