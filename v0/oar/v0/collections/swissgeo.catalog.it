            "dir": "ltr",
            "name": "Italiano"
          },
          {
            "code": "en",
            "dir": "ltr",
            "name": "English"
          }
        ],
        "preferredDistributionId": "ch.bafu.fauna-steinbockkolonien:wmts",
        "title": "Colonie di stambecchi",
        "type": "Dataset"
      }
