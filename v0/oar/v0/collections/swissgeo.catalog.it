            "code": "it",
            "dir": "ltr",
            "name": "Italiano"
          },
          {
            "code": "en",
            "dir": "ltr",
            "name": "English"
          }
        ],
        "preferredDistributionId": "ch.bfe.biogasanlagen:wms",
        "title": "Impianti di produzione di biogas",
        "type": "Dataset"
      }
