    {
      "id": "ch.bafu.bundesinventare-amphibien",
      "links": [
        {
          "href": "https://services.dev.sgdi.tech/api/oar/v0/collections/swissgeo.catalog/items/ch.bafu.bundesinventare-amphibien?language=it",
