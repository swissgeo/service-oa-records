            "code": "it",
            "dir": "ltr",
            "name": "Italiano"
          },
          {
            "code": "en",
            "dir": "ltr",
            "name": "English"
          }
        ],
        "preferredDistributionId": "ch.swisstopo.pixelkarte-pk50.metadata:wms",
        "title": "Découpage carte nationale 50 Raster",
        "type": "Dataset"
      }
    },
