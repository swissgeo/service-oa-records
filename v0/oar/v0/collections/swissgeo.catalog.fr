            "dir": "ltr",
            "name": "Italiano"
          },
          {
            "code": "en",
            "dir": "ltr",
            "name": "English"
          }
        ],
        "preferredDistributionId": "ch.bfe.windenergie-geschwindigkeit_h50:wms",
        "title": "Vitesse du vent à 50 m du sol",
        "type": "Dataset"
      }
