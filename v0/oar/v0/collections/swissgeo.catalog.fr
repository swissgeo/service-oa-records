            "code": "it",
            "dir": "ltr",
            "name": "Italiano"
          },
          {
            "code": "en",
            "dir": "ltr",
            "name": "English"
          }
        ],
        "preferredDistributionId": "ch.bafu.landesforstinventar-vegetationshoehenmodell_relief:wmts",
        "title": "Modèle de surface IFN",
        "type": "Dataset"
      }
    },
