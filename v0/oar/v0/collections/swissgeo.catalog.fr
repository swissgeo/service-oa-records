            "name": "Italiano"
          },
          {
            "code": "en",
            "dir": "ltr",
            "name": "English"
          }
        ],
        "preferredDistributionId": "ch.bafu.wrz-jagdbanngebiete_select:wmts",
        "title": "Sites de protection de la faune",
        "type": "Dataset"
      }
