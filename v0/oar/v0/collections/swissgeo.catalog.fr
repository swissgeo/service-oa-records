            "code": "it",
            "dir": "ltr",
            "name": "Italiano"
          },
          {
            "code": "en",
            "dir": "ltr",
            "name": "English"
          }
        ],
        "preferredDistributionId": "ch.bafu.neophyten-grossbluetiges_heusenkraut:wmts",
        "title": "Ludwigie à grandes fleurs",
        "type": "Dataset"
      }
