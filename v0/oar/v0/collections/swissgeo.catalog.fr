            "name": "Italiano"
          },
          {
            "code": "en",
            "dir": "ltr",
            "name": "English"
          }
        ],
        "preferredDistributionId": "ch.meteoschweiz.hagelgefaehrdung-korngroesse_20_jahre:wms",
        "title": "Danger grêle (taille), 20 ans",
        "type": "Dataset"
      }
