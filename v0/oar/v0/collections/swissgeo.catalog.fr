            "name": "Italiano"
          },
          {
            "code": "en",
            "dir": "ltr",
            "name": "English"
          }
        ],
        "preferredDistributionId": "ch.bafu.geochemischer-bodenatlas_schweiz_uran:wmts",
        "title": "Concentrations d'uranium dans le sol",
        "type": "Dataset"
      }
