            "dir": "ltr",
            "name": "English"
          }
        ],
        "preferredDistributionId": "ch.bfe.ladebedarfswelt-heimladeverfuegbarkeit_geplant:wmts",
        "title": "Besoin en charge: Disponibilité de la recharge à domicile - Planifié",
        "type": "Dataset"
      }
