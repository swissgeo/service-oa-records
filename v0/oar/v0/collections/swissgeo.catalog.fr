    {
      "id": "ch.bafu.niederschlagserosivitaet-nov",
      "links": [
        {
          "href": "https://services.dev.sgdi.tech/api/oar/v0/collections/swissgeo.catalog/items/ch.bafu.niederschlagserosivitaet-nov?language=fr",
