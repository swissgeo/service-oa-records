            "code": "it",
            "dir": "ltr",
            "name": "Italiano"
          },
          {
            "code": "en",
            "dir": "ltr",
            "name": "English"
          }
        ],
        "preferredDistributionId": "ch.bfe.waermepotential-gewaesser:wms",
        "title": "Potentiel thermique des eaux",
        "type": "Dataset"
      }
    },
