            "dir": "ltr",
            "name": "Français"
          },
          {
            "alternate": "Italian",
            "code": "it",
            "dir": "ltr",
            "name": "Italiano"
          },
          {
            "code": "en",
            "dir": "ltr",
            "name": "English"
          }
        ],
        "preferredDistributionId": "ch.bfe.windenergie-geschwindigkeit_h100:wms",
        "title": "Vitesse du vent à 100 m du sol",
        "type": "Dataset"
      }
