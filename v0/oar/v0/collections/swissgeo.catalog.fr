            "name": "Français"
          },
          {
            "alternate": "Italian",
            "code": "it",
            "dir": "ltr",
            "name": "Italiano"
          },
          {
            "code": "en",
            "dir": "ltr",
            "name": "English"
          }
        ],
        "preferredDistributionId": "ch.bafu.wald-foehnhaeufigkeit_jahr:wmts",
        "title": "Fréquence de foehn",
        "type": "Dataset"
      }
    },
    {
