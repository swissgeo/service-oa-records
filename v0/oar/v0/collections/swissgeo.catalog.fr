    {
      "id": "ch.bafu.niederschlagserosivitaet-mai",
      "links": [
        {
          "href": "https://services.dev.sgdi.tech/api/oar/v0/collections/swissgeo.catalog/items/ch.bafu.niederschlagserosivitaet-mai?language=fr",
