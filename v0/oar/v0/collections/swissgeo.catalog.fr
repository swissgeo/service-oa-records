    {
      "id": "ch.bafu.niederschlagserosivitaet-jan",
      "links": [
        {
          "href": "https://services.dev.sgdi.tech/api/oar/v0/collections/swissgeo.catalog/items/ch.bafu.niederschlagserosivitaet-jan?language=fr",
