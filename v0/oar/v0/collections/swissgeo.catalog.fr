        "title": "Alpages protégés par des chiens",
        "type": "Dataset"
      }
    },
    {
      "id": "ch.bafu.amphibienwanderung-verkehrskonflikte",
      "links": [
        {
          "href": "https://services.dev.sgdi.tech/api/oar/v0/collections/swissgeo.catalog/items/ch.bafu.amphibienwanderung-verkehrskonflikte?language=fr",
