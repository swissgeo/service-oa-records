            "name": "Italiano"
          },
          {
            "code": "en",
            "dir": "ltr",
            "name": "English"
          }
        ],
        "preferredDistributionId": "ch.bafu.geochemischer-bodenatlas_schweiz_natrium:wmts",
        "title": "Concentrations de sodium dans le sol",
        "type": "Dataset"
      }
