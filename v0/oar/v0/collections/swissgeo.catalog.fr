            "name": "Italiano"
          },
          {
            "code": "en",
            "dir": "ltr",
            "name": "English"
          }
        ],
        "preferredDistributionId": "ch.bafu.niederschlagserosivitaet-sep:wmts",
        "title": "Action érosive précipitations sep.",
        "type": "Dataset"
      }
