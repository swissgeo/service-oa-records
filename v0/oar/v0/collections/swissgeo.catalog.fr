            "name": "Italiano"
          },
          {
            "code": "en",
            "dir": "ltr",
            "name": "English"
          }
        ],
        "preferredDistributionId": "ch.bafu.luftreinhaltung-stickstoffdioxid:wmts",
        "title": "Dioxyde d'azote NO₂",
        "type": "Dataset"
      }
