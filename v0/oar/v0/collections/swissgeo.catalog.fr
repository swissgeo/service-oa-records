            "code": "it",
            "dir": "ltr",
            "name": "Italiano"
          },
          {
            "code": "en",
            "dir": "ltr",
            "name": "English"
          }
        ],
        "preferredDistributionId": "ch.swisstopo.geologie-rohstoffe-vererzungen:wms",
        "title": "Matières premières métalliques",
        "type": "Dataset"
      }
    },
