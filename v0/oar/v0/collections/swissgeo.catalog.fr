            "dir": "ltr",
            "name": "Italiano"
          },
          {
            "code": "en",
            "dir": "ltr",
            "name": "English"
          }
        ],
        "preferredDistributionId": "ch.bafu.geochemischer-bodenatlas_schweiz_arsen:wmts",
        "title": "Concentrations d'arsenic dans le sol",
        "type": "Dataset"
      }
