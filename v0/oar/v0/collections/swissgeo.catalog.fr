            "dir": "ltr",
            "name": "Italiano"
          },
          {
            "code": "en",
            "dir": "ltr",
            "name": "English"
          }
        ],
        "preferredDistributionId": "ch.swisstopo.geologie-dosisleistung-terrestrisch:wmts",
        "title": "Radiation terrestre",
        "type": "Dataset"
      }
    },
