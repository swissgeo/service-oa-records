            "dir": "ltr",
            "name": "Français"
          },
          {
            "alternate": "Italian",
            "code": "it",
            "dir": "ltr",
            "name": "Italiano"
          },
          {
            "code": "en",
            "dir": "ltr",
            "name": "English"
          }
        ],
        "preferredDistributionId": "ch.swisstopo.geologie-gesteinsdichte:wmts",
        "title": "Densité des roches",
        "type": "Dataset"
      }
