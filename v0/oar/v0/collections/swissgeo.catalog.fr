            "name": "Italiano"
          },
          {
            "code": "en",
            "dir": "ltr",
            "name": "English"
          }
        ],
        "preferredDistributionId": "ch.bfe.grundwasserwaermenutzungspotential:wmts",
        "title": "Potentiel d'exploitation de la chaleur des eaux souterraines",
        "type": "Dataset"
      }
