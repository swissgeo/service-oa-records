            "dir": "ltr",
            "name": "Italiano"
          },
          {
            "code": "en",
            "dir": "ltr",
            "name": "English"
          }
        ],
        "preferredDistributionId": "ch.bafu.neophyten-fortunes_hanfpalme:wmts",
        "title": "Palmier chanvre",
        "type": "Dataset"
      }
    },
