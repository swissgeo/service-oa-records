            "code": "it",
            "dir": "ltr",
            "name": "Italiano"
          },
          {
            "code": "en",
            "dir": "ltr",
            "name": "English"
          }
        ],
        "preferredDistributionId": "ch.meteoschweiz.hagelgefaehrdung-korngroesse_100_jahre:wms",
        "title": "Danger grêle (taille), 100 ans",
        "type": "Dataset"
      }
