    {
      "id": "ch.bafu.geochemischer-bodenatlas_schweiz_molybdaen",
      "links": [
        {
          "href": "https://services.dev.sgdi.tech/api/oar/v0/collections/swissgeo.catalog/items/ch.bafu.geochemischer-bodenatlas_schweiz_molybdaen?language=fr",
          "rel": "self",
