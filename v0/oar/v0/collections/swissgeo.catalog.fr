            "dir": "ltr",
            "name": "Italiano"
          },
          {
            "code": "en",
            "dir": "ltr",
            "name": "English"
          }
        ],
        "preferredDistributionId": "ch.bafu.geochemischer-bodenatlas_schweiz_eisen:wmts",
        "title": "Concentrations de fer dans le sol",
        "type": "Dataset"
      }
