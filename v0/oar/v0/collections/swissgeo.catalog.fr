            "name": "Français"
          },
          {
            "alternate": "Italian",
            "code": "it",
            "dir": "ltr",
            "name": "Italiano"
          },
          {
            "code": "en",
            "dir": "ltr",
            "name": "English"
          }
        ],
        "preferredDistributionId": "ch.swisstopo.hebungsraten:wms",
        "title": "Mouvements verticaux",
        "type": "Dataset"
      }
