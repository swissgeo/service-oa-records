          },
          {
            "code": "en",
            "dir": "ltr",
            "name": "English"
          }
        ],
        "preferredDistributionId": "ch.bafu.hydrologie-q347:wmts",
        "title": "Eléments pour déterminer Q347",
        "type": "Dataset"
      }
