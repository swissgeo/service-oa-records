    {
      "id": "ch.bafu.niederschlagserosivitaet-aug",
      "links": [
        {
          "href": "https://services.dev.sgdi.tech/api/oar/v0/collections/swissgeo.catalog/items/ch.bafu.niederschlagserosivitaet-aug?language=fr",
          "rel": "self",
