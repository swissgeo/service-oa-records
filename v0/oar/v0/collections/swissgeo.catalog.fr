            "dir": "ltr",
            "name": "Italiano"
          },
          {
            "code": "en",
            "dir": "ltr",
            "name": "English"
          }
        ],
        "preferredDistributionId": "ch.bafu.geochemischer-bodenatlas_schweiz_calcium:wmts",
        "title": "Concentrations de Calcium dans le sol",
        "type": "Dataset"
      }
